'''
Welcome! Here is the code to our allowance splitter, this simple module can take any number 
(especially your allowance amount), split into your needs, wants and savings, for effective
spending, and saving, we now have a new feature called the savings goal, you type your goal
to save, and it'll show you how long it'll take for you to reach that savings goal, we also
added a split value mechanic, you input your allowance, and you have the option to add a new
subcategory on the "needs" category, just type its name, and add the percentage, to make it 
more personalized and specific for the user, we also added the "lower" string method, so that 
when the user has the correct spelling but the incorrect casing, it automatically turns the
incorrect casing to lowercase, so there will be less issues and will be more cleared up and
usable.
'''

import math

# 1st function: Keeps your "nothing typed" logic for everything else
def AllowanceInput(message, is_numeric=True):
    while True:
        user_input = input(message).strip()
        
        if user_input == "":
            print("Error: You didn't type anything. Please try again.")
            continue
        
        if is_numeric:
            try:
                return float(user_input)
            except ValueError:
                print("Error: Please enter a valid number.")
                continue
        return user_input

def AllowanceDisplay(total, needs, wants, savings):
    print("\n--- BUDGET SUMMARY ---")
    print("Total: ₱", total)
    print("Needs (50%): ₱", needs)
    print("Wants (30%): ₱", wants)
    print("Savings (20%): ₱", savings)
    print("----------------------")

# the main program!!!
print("---ALLOWANCE SPLITTER---")
print("Welcome, to our Allowance Splitter! This program will be able to help you split your allowance! (like the name suggests), we've added 2 new features, a savings goal, and a needs division!")

user_name = input("Hello there! Please enter your name: ")

while True:
    print("\nHello, ", user_name, "!")
    print("[ MENU ]")
    print("1. Calculate Allowance")
    print("2. Exit")
    
    choice = AllowanceInput("Select 1 or 2: ", is_numeric=False)

    if choice == "1":
        weekly_cash = AllowanceInput("Enter your weekly allowance: ₱")
        
        needs_amt = weekly_cash * 0.50
        wants_amt = weekly_cash * 0.30
        savings_amt = weekly_cash * 0.20

        AllowanceDisplay(weekly_cash, needs_amt, wants_amt, savings_amt)

        ask_split = AllowanceInput("Split your Needs (₱" + str(needs_amt) + ")? (yes/no): ", is_numeric=False)
        
        if ask_split.lower() == "yes":
            items_to_add = int(AllowanceInput("How many sub-categories? "))
            
            percent_count = 0
            for i in range(items_to_add):
                item_name = AllowanceInput("Name of item " + str(i+1) + ": ", is_numeric=False)
                item_percent = AllowanceInput("Percentage for " + item_name + " (e.g. 20): ")
                
                if percent_count + item_percent <= 100:
                    cost = needs_amt * (item_percent / 100)
                    percent_count += item_percent
                    print(">> ₱", cost, "set for", item_name)
                else:
                    print("Error: Percent total exceeded 100%!")

        ask_goal = AllowanceInput("Track a savings goal? (yes/no): ", is_numeric=False)
        if ask_goal.lower() == "yes":
            goal_name = AllowanceInput("What are you saving for? ", is_numeric=False)
            goal_cost = AllowanceInput("How much does it cost? ₱")
            
            weeks_needed = math.ceil(goal_cost / savings_amt)
            days_needed = weeks_needed * 7
            
            print("To buy " + goal_name + ", you need to save for " + str(days_needed) + " days.")

    elif choice == "2":
        print("Goodbye, " + user_name + "!")
        break
    else:
        print("Invalid choice. Try again.")
